# Copy to a private file (never commit). In WSL:
#   export NOVA_TELEGRAM_OWNER_ID="123456789"
#   export TELEGRAM_BOT_TOKEN="your_token"   # or rely on OpenClaw gateway .env
#   export OLLAMA_API_KEY="ollama-local"
# Optional: cloud emergency fallback (OpenClaw openrouter provider)
#   export OPENROUTER_API_KEY="sk-or-..."
#
# If the OpenClaw gateway runs in Docker and Ollama is on the Windows/WSL host:
#   export NOVA_OLLAMA_BASE_URL="http://host.docker.internal:11434"

NOVA_TELEGRAM_OWNER_ID=
TELEGRAM_BOT_TOKEN=
OLLAMA_API_KEY=ollama-local
OPENROUTER_API_KEY=
NOVA_OLLAMA_BASE_URL=http://127.0.0.1:11434
