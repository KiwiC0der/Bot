# Example: web_search / web_fetch API keys for OpenClaw gateway (Docker).
# Copy lines into ~/openclaw/openclaw/email.env (stock compose uses env_file: ./email.env),
# or create web.env and add "- ./web.env" under env_file for openclaw-gateway in docker-compose.yml.
#
# Do not commit real keys.

# Free-tier search (typical): Google AI Studio → GEMINI_API_KEY, and set tools.web.search.provider to "gemini" if you also use Brave.
# GEMINI_API_KEY=

# BRAVE_API_KEY=
# FIRECRAWL_API_KEY=
# GEMINI_API_KEY=
# PERPLEXITY_API_KEY=
# OPENROUTER_API_KEY=
